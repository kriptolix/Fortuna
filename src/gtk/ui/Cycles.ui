<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="Cycles" parent="GtkBox">
    <property name="orientation">1</property>
    <property name="hexpand">false</property>
    <property name="halign">3</property>
    <property name="valign">1</property>
    <property name="margin-bottom">25</property>
    <property name="margin-top">50</property>
    <property name="spacing">15</property>
    <child>
      <object class="GtkBox">
        <property name="spacing">15</property>
        <property name="orientation">1</property>
        <property name="halign">3</property>
        <child>
          <object class="GtkDropDown" id="_weather_combo">
            <property name="enable-search">false</property>
            <property name="width-request">210</property>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="_seasons_combo">
            <property name="enable-search">false</property>
            <property name="width-request">210</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="spacing">20</property>
            <child>
              <object class="GtkButton" id="_weather_button">
                <property name="label" translatable="yes">Weather</property>
                <property name="valign">3</property>
                <property name="vexpand">false</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="_moon_button">
                <property name="label" translatable="yes">Moon Phase</property>
                <property name="valign">3</property>
                <property name="halign">2</property>
                <property name="vexpand">false</property>
                <property name="hexpand">true</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkOverlay">
        <child>
          <object class="GtkPicture" id="_background"></object>
        </child>
        <child type="overlay">
          <object class="GtkLabel" id="_weather_label">
            <property name="label" translatable="yes">No Weahter...</property>
            <property name="margin-top">50</property>
            <style>
              <class name="title-1"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>